<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Signup</title>
  <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
</head>
<body class="bg-gray-100 flex items-center justify-center min-h-screen">
  <div class="bg-white p-8 rounded-lg shadow-md w-full max-w-md">
    <h1 class="text-2xl font-bold mb-6 text-center">Signup</h1>
    <% if (error) { %>
      <p class="text-red-500 mb-4"><%= error %></p>
    <% } %>
    <form action="/signup" method="POST">
      <div class="mb-4">
        <label class="block text-gray-700">Username</label>
        <input type="text" name="username" required class="w-full px-3 py-2 border rounded-lg">
      </div>
      <div class="mb-4">
        <label class="block text-gray-700">Email</label>
        <input type="email" name="email" required class="w-full px-3 py-2 border rounded-lg">
      </div>
      <div class="mb-4">
        <label class="block text-gray-700">Password</label>
        <input type="password" name="password" required class="w-full px-3 py-2 border rounded-lg">
      </div>
      <div class="mb-4">
        <label class="block text-gray-700 mb-2">Choose Avatar</label>
        <div class="grid grid-cols-3 gap-2">
          <% avatars.forEach(avatar => { %>
            <label class="cursor-pointer">
              <input type="radio" name="avatar" value="<%= avatar %>" required class="hidden">
              <img src="https://via.placeholder.com/64?text=<%= avatar.replace('.png','') %>" alt="Avatar" class="w-16 h-16 rounded-full border-2 border-gray-300 hover:border-blue-500">
            </label>
          <% }); %>
        </div>
      </div>
      <button type="submit" class="w-full bg-blue-500 text-white py-2 rounded-lg hover:bg-blue-600">Signup</button>
    </form>
    <p class="mt-4 text-center">Already have an account? <a href="/login" class="text-blue-500">Login</a></p>
  </div>
</body>
</html>