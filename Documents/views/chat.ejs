<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Chat with <%= otherUser.username %></title>
  <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
</head>
<body class="bg-gray-100 min-h-screen">
  <div class="container mx-auto p-8">
    <div class="flex justify-between items-center mb-8">
      <h1 class="text-3xl font-bold">Chat with <%= otherUser.username %></h1>
      <a href="/users" class="bg-gray-500 text-white px-4 py-2 rounded-lg hover:bg-gray-600">Back to Users</a>
    </div>
    <div class="bg-white p-6 rounded-lg shadow-md mb-6 max-h-96 overflow-y-auto">
      <% messages.forEach(message => { %>
        <div class="mb-4 flex items-start">
          <img src="https://via.placeholder.com/40?text=<%= message.from.avatar.replace('.png','') %>" alt="Avatar" class="w-10 h-10 rounded-full mr-4">
          <div>
            <p class="font-semibold"><%= message.from.username %></p>
            <p class="text-gray-700"><%= message.content %></p>
            <p class="text-sm text-gray-500"><%= new Date(message.timestamp).toLocaleString() %></p>
          </div>
        </div>
      <% }); %>
      <% if (messages.length === 0) { %>
        <p class="text-center text-gray-500">No messages yet. Start the conversation!</p>
      <% } %>
    </div>
    <form action="/chat/<%= otherUser._id %>" method="POST" class="bg-white p-6 rounded-lg shadow-md">
      <div class="mb-4">
        <label class="block text-gray-700 mb-2">Your Message</label>
        <textarea name="message" required class="w-full px-3 py-2 border rounded-lg" rows="3"></textarea>
      </div>
      <button type="submit" class="bg-blue-500 text-white px-4 py-2 rounded-lg hover:bg-blue-600">Send Message</button>
    </form>
  </div>
</body>
</html>